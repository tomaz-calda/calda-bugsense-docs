            "pages": [
              "api-reference/reports/list-reports",
              "api-reference/reports/get-report",
              "api-reference/reports/update-report",
              "api-reference/reports/approve-report"
            ]
          },
          {
            "group": "Linear integration",
            "pages": [
              "api-reference/integrations/linear-connect",
              "api-reference/integrations/linear-callback",
              "api-reference/integrations/linear-connection",
              "api-reference/integrations/linear-teams",
