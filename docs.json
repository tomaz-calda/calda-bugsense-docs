{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BugSense",
  "colors": {
    "primary": "#FF3D00",
    "light": "#FF6B33",
    "dark": "#080808"
  },
  "favicon": "/favicon-calda.svg",
  "icons": {
    "library": "lucide"
  },
  "navigation": {
