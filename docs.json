            "pages": [
              "integrations/linear",
              "integrations/slack",
              "integrations/email",
              "integrations/openai",
              "integrations/chatgpt"
            ]
          },
          {
            "group": "Development",
            "pages": ["architecture", "authentication", "data-model", "quickstart"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Users",
            "pages": [
              "api-reference/users/get-me",
              "api-reference/users/update-me",
              "api-reference/users/update-profile-image",
